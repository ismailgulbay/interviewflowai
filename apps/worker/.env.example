NODE_ENV=development
LOG_LEVEL=info
WORKER_CONCURRENCY=5
RABBITMQ_QUEUE=evaluation.jobs
RABBITMQ_PREFETCH=5
MAX_RETRY_COUNT=3
RETRY_BACKOFF_MS=2000
